# =============================================================================
# Digivixo Voice AI Platform — environment variables
#
# Every key listed as ACTIVE is referenced somewhere in the code right now.
# Keys under "UPCOMING" are defined in docs/02-manual-admin-steps (section 8)
# and will move up to ACTIVE as the prompts that reference them are built.
# Placeholder values only — real credentials live in .env (never committed).
# =============================================================================

# --- ACTIVE (referenced in code as of Prompt 5) ------------------------------

# Neon Postgres — use the POOLED connection string, not the direct one
# (Next.js serverless functions exhaust direct connections under load).
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Upstash Redis via its REST API — webhook idempotency,
# live-call status cache, dead-letter list, and global auth rate limiting.
# live-call cache, dead-letter lists and auth rate limiting. Copy BOTH values
# from the Upstash console's "REST API" tab (not the TCP/rediss:// string).
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Retell API key — also what Retell signs webhooks with (there is no separate
# signing key). Used to verify x-retell-signature on /api/webhooks/retell.
RETELL_API_KEY=your_retell_api_key

# Cloudflare R2 (permanent call-recording storage, S3-compatible API).
# Credentials must be scoped to this ONE bucket, and the bucket must NOT be
# public — playback goes through short-lived presigned URLs only (docs/02 §5).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name

# Session JWT signing/encryption secret. Generate with:
#   openssl rand -base64 32   (or any 32+ byte random string)
AUTH_SECRET=generate_a_random_32_byte_secret

# Public origin of the deployed app, no trailing slash. Used to build the
# set-password email link and the Polar checkout success redirect.
APP_URL=https://yourdomain.com

# Resend (transactional email) — domain must be verified (SPF/DKIM/DMARC).
RESEND_API_KEY=your_resend_api_key
# The From address for all outgoing mail, on the verified domain.
EMAIL_FROM=Digivixo <notifications@yourdomain.com>
# OPTIONAL: Reply-To on all outgoing mail, so replies land in a monitored
# inbox instead of the notifications address. Omit to send no header.
REPLY_TO=contact@yourdomain.com

# Polar (billing) — API token + webhook signing secret from the Polar dashboard.
POLAR_ACCESS_TOKEN=your_polar_api_access_token
POLAR_WEBHOOK_SECRET=your_polar_webhook_signing_secret
# 'production' for a live Polar org (current setup — no sandbox org exists);
# test the checkout flow with a 100%-off discount code instead (see
# OPERATIONS.md §4).
POLAR_ENVIRONMENT=production
# Product IDs of the three subscription products created manually in Polar.
POLAR_PRODUCT_ID_PILOT=polar_product_id_for_pilot
POLAR_PRODUCT_ID_STANDARD=polar_product_id_for_standard
POLAR_PRODUCT_ID_PRO=polar_product_id_for_pro

# Admin bootstrap — read ONLY by `npm run seed:admin` (safe to clear after).
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=a_strong_password_at_least_12_chars

# Upstash QStash — drives all scheduled jobs (/api/jobs/*), replacing Vercel
# Cron. All three values are on the QStash page of the Upstash console.
# The signing keys verify that job requests really come from QStash.
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key
# Token is read ONLY by `npm run qstash:setup` (registers the schedules —
# run once per environment, after APP_URL points at the deployed domain).
QSTASH_TOKEN=your_qstash_token

# --- UPCOMING ----------------------------------------------------------------
# (none — every key from docs/02 §8 is now referenced in code)
